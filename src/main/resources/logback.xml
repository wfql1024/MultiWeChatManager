<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- 日志输出目录由 Launcher 通过 System.setProperty("jfmultichat.logdir", ...) 设置
         Logback 自动解析 ${jfmultichat.logdir} 系统属性 -->

    <!-- 控制台输出 -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- 文件输出 — 按天滚动，保留 7 天 -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${jfmultichat.logdir}/jfmultichat.log</file>
        <append>true</append>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${jfmultichat.logdir}/jfmultichat.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>7</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- JavaFX / WebView 日志级别 — 降低噪音 -->
    <logger name="javafx" level="WARN"/>
    <logger name="com.sun.webkit" level="WARN"/>
    <logger name="com.sun.javafx" level="WARN"/>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>
</configuration>
